# Required — Anthropic powers all agent responses
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5

# Backend tuning (optional — lower max_tokens = faster replies)
MAX_TOKENS=384
MAX_TOKENS_TOOL_STEP=256
MAX_LLM_CONTEXT_TURNS=4
SUGGESTED_REPLY_DELAY_MS=1100

# Backend — comma-separated allowed browser origins
CORS_ORIGINS=http://localhost:3000

# Frontend (local dev / Vercel build)
NEXT_PUBLIC_API_URL=http://localhost:8080
